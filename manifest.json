{
  "manifest_version": 3,
  "name": "Av.Yusuf AVCI Uyap",
  "version": "1.1.0",
  "description": "Av.Yusuf Avci tarafindan sahsi kullanim amaciyla UYAP oto girisi icin olusturulmustur.",
  "update_url": "https://raw.githubusercontent.com/avcihub/uyap-auto-login-extension/main/updates.xml",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*/*",
    "file:///*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "Av.Yusuf AVCI Uyap",
    "default_popup": "popup.html"
  }
}

